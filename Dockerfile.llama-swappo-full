# syntax=docker/dockerfile:1

ARG LLAMA_SWAP_REF=

FROM node:24-bookworm AS llama-swap-ui-build

ARG LLAMA_SWAP_REPO=https://github.com/mostlygeek/llama-swap.git
ARG LLAMA_SWAP_REF

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    rm -f /etc/apt/apt.conf.d/docker-clean \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates \
      git

WORKDIR /src

RUN git clone --filter=blob:none "${LLAMA_SWAP_REPO}" llama-swap \
 && if [ -n "${LLAMA_SWAP_REF}" ]; then git -C llama-swap checkout "${LLAMA_SWAP_REF}"; fi

WORKDIR /src/llama-swap/ui-svelte

RUN --mount=type=cache,id=llama-swap-ui-npm,target=/root/.npm,sharing=locked \
    npm ci \
 && npm run build


FROM golang:1.26.1-bookworm AS llama-swap-build

ARG LLAMA_SWAP_REPO=https://github.com/mostlygeek/llama-swap.git
ARG LLAMA_SWAP_REF

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    rm -f /etc/apt/apt.conf.d/docker-clean \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates \
      git

WORKDIR /src

RUN git clone --filter=blob:none "${LLAMA_SWAP_REPO}" llama-swap \
 && if [ -n "${LLAMA_SWAP_REF}" ]; then git -C llama-swap checkout "${LLAMA_SWAP_REF}"; fi

COPY docker/llama-swappo/ollama-api.patch /tmp/ollama-api.patch

RUN git -C llama-swap apply --unidiff-zero /tmp/ollama-api.patch

COPY --from=llama-swap-ui-build /src/llama-swap/internal/server/ui_dist /src/llama-swap/internal/server/ui_dist

WORKDIR /src/llama-swap

RUN --mount=type=cache,id=llama-swap-go-mod,target=/go/pkg/mod,sharing=locked \
    --mount=type=cache,id=llama-swap-go-build,target=/root/.cache/go-build,sharing=locked \
    GIT_HASH="$(git rev-parse --short HEAD)-swappo" \
 && BUILD_DATE="$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
 && GOOS=linux GOARCH=amd64 go build \
      -ldflags="-X main.commit=${GIT_HASH} -X main.version=0.13.5 -X main.date=${BUILD_DATE}" \
      -o /out/llama-swap


FROM nvidia/cuda:12.6.3-devel-ubuntu24.04 AS sd-build

ARG DEBIAN_FRONTEND=noninteractive
ENV CCACHE_DIR=/root/.cache/ccache
ENV PATH="/usr/lib/ccache:${PATH}"

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    rm -f /etc/apt/apt.conf.d/docker-clean \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates \
      git \
      cmake \
      build-essential \
      pkg-config \
      ccache

WORKDIR /tmp/build

RUN git clone --recursive https://github.com/leejet/stable-diffusion.cpp.git

RUN --mount=type=cache,id=sd-cmake-build-cuda-86,target=/tmp/build/stable-diffusion.cpp/build,sharing=locked \
    --mount=type=cache,id=sd-ccache-cuda-86,target=/root/.cache/ccache,sharing=locked \
    cmake -S stable-diffusion.cpp -B stable-diffusion.cpp/build \
      -DSD_CUDA=ON \
      -DCMAKE_CUDA_ARCHITECTURES=86 \
      -DCMAKE_BUILD_TYPE=Release \
 && cmake --build stable-diffusion.cpp/build --config Release -j"$(nproc)" \
 && mkdir -p /out/bin \
 && cp stable-diffusion.cpp/build/bin/sd-server /out/bin/sd-server \
 && cp stable-diffusion.cpp/build/bin/sd-cli /out/bin/sd-cli


FROM ghcr.io/mostlygeek/llama-swap:unified-cuda

USER root

COPY --from=llama-swap-build /out/llama-swap /usr/local/bin/llama-swap
COPY --from=sd-build /out/bin/sd-server /usr/local/bin/sd-server
COPY --from=sd-build /out/bin/sd-cli /usr/local/bin/sd-cli

RUN chmod 0755 /usr/local/bin/llama-swap /usr/local/bin/sd-server /usr/local/bin/sd-cli

WORKDIR /app
