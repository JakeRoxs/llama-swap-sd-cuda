+func (s *Server) handleOllamaTags(w http.ResponseWriter, r *http.Request) {
+	ids := make([]string, 0, len(s.cfg.Models))
+	for id, modelCfg := range s.cfg.Models {
+		if !modelCfg.Unlisted {
+			ids = append(ids, id)
+		}
+	}
+	sort.Strings(ids)
+
+	now := time.Now().UTC()
+	models := make([]ollamaModelResponse, 0, len(ids))
+	for _, id := range ids {
+		modelCfg := s.cfg.Models[id]
+		models = append(models, ollamaModelResponse{
+			Name:         id,
+			Model:        id,
+			ModifiedAt:   now,
+			Size:         0,
+			Digest:       digestForModel(id),
+			Details:      ollamaDetailsForModel(id, modelCfg),
+			Capabilities: ollamaCapabilitiesForModel(modelCfg),
+		})
+	}
+
+	setOllamaCORS(w, r)
+	writeOllamaJSON(w, http.StatusOK, map[string]any{"models": models})
+}
+
+func (s *Server) handleOllamaShow(w http.ResponseWriter, r *http.Request) {
+	var req ollamaShowRequest
+	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
+		writeOllamaError(w, http.StatusBadRequest, fmt.Sprintf("Invalid request: %v", err))
+		return
+	}
+	modelName := firstNonEmpty(req.Model, req.Name)
+	if modelName == "" {
+		writeOllamaError(w, http.StatusBadRequest, "Model name is required.")
+		return
+	}
+
+	modelCfg, realName, ok := s.cfg.FindConfig(modelName)
+	if !ok {
+		writeOllamaError(w, http.StatusNotFound, fmt.Sprintf("Model '%s' not found.", modelName))
+		return
+	}
+
+	parsed := NewLlamaServerParser().Parse(modelCfg.Cmd, realName)
+	metadata := modelCfg.Metadata
+	arch := metadataString(metadata, "architecture", parsed.Architecture)
+	details := ollamaDetailsForModel(realName, modelCfg)
+	if details.Family == "" {
+		details.Family = parsed.Family
+	}
+	if details.ParameterSize == "" {
+		details.ParameterSize = parsed.ParameterSize
+	}
+	if details.QuantizationLevel == "" {
+		details.QuantizationLevel = parsed.QuantizationLevel
+	}
+	if details.ContextLength == 0 {
+		details.ContextLength = metadataInt(metadata, "contextLength", parsed.ContextLength)
+	}
+
+	modelInfo := map[string]any{"general.architecture": arch}
+	ctxLength := details.ContextLength
+	if ctxLength > 0 {
+		modelInfo[fmt.Sprintf("%s.context_length", arch)] = ctxLength
+	}
+
+	setOllamaCORS(w, r)
+	writeOllamaJSON(w, http.StatusOK, ollamaShowResponse{
+		Modelfile:    modelCfg.Cmd,
+		Details:      details,
+		ModelInfo:    modelInfo,
+		Capabilities: ollamaCapabilitiesForModel(modelCfg),
+		ModifiedAt:   time.Now().UTC(),
+	})
+}
+
+func (s *Server) handleOllamaPS(w http.ResponseWriter, r *http.Request) {
+	running := s.local.RunningModels()
+	ids := make([]string, 0, len(running))
+	for id := range running {
+		ids = append(ids, id)
+	}
+	sort.Strings(ids)
+
+	now := time.Now().UTC()
+	models := make([]ollamaProcessModelResponse, 0, len(ids))
+	for _, id := range ids {
+		cfg := s.cfg.Models[id]
+		expiresAt := time.Time{}
+		if cfg.UnloadAfter > 0 {
+			expiresAt = now.Add(time.Duration(cfg.UnloadAfter) * time.Second)
+		}
+		models = append(models, ollamaProcessModelResponse{
+			Name:      id,
+			Model:     id,
+			Size:      0,
+			Digest:    digestForModel(id),
+			Details:   ollamaDetailsForModel(id, cfg),
+			ExpiresAt: expiresAt,
+			SizeVRAM:  0,
+		})
+	}
+
+	setOllamaCORS(w, r)
+	writeOllamaJSON(w, http.StatusOK, ollamaProcessResponse{Models: models})
+}
