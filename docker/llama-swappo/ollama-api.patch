+package server
+
+import (
+	"crypto/sha256"
+	"fmt"
+	"path/filepath"
+	"regexp"
+	"strconv"
+	"strings"
+
+	"github.com/mostlygeek/llama-swap/internal/config"
+)
+
+type OllamaServerArgs struct {
+	Architecture      string
+	ContextLength     int
+	Capabilities      []string
+	Family            string
+	ParameterSize     string
+	QuantizationLevel string
+	CmdAlias          string
+	CmdModelPath      string
+}
+
+type LlamaServerParser struct{}
+
+var (
+	ollamaArchitecturePatterns = map[string]*regexp.Regexp{
+		"command-r": regexp.MustCompile(`(?i)command-r`), "gemma3": regexp.MustCompile(`(?i)gemma3`), "gemma2": regexp.MustCompile(`(?i)gemma2`), "gemma": regexp.MustCompile(`(?i)gemma`), "llama4": regexp.MustCompile(`(?i)llama-?4`), "llama3": regexp.MustCompile(`(?i)llama-?3`), "llama": regexp.MustCompile(`(?i)llama`), "mistral": regexp.MustCompile(`(?i)mistral`), "phi": regexp.MustCompile(`(?i)phi`), "qwen3": regexp.MustCompile(`(?i)qwen-?3`), "qwen2": regexp.MustCompile(`(?i)qwen-?2`), "qwen": regexp.MustCompile(`(?i)qwen`), "bert": regexp.MustCompile(`(?i)bert`), "clip": regexp.MustCompile(`(?i)clip`),
+	}
+	ollamaOrderedArchKeys      = []string{"command-r", "gemma3", "gemma2", "gemma", "llama4", "llama3", "llama", "mistral", "phi", "qwen3", "qwen2", "qwen", "bert", "clip"}
+	ollamaParameterSizePattern = regexp.MustCompile(`(?i)(\d+(?:\.\d+)?(?:x\d+)?)[BMGT]?B`)
+	ollamaQuantizationPatterns = []*regexp.Regexp{regexp.MustCompile(`(?i)IQ[1-4]_(XXS|XS|S|M|NL)`), regexp.MustCompile(`(?i)Q[2-8]_(0|1|[KSLM]+(?:_[KSLM]+)?)`), regexp.MustCompile(`(?i)F(?:P)?(16|32)`), regexp.MustCompile(`(?i)BF16`)}
+)
+
+func NewLlamaServerParser() *LlamaServerParser {
+	return &LlamaServerParser{}
+}
+
+func (p *LlamaServerParser) Parse(cmdStr string, modelID string) OllamaServerArgs {
+	parsed := OllamaServerArgs{Capabilities: []string{"completion"}}
+	args, err := config.SanitizeCommand(cmdStr)
+	if err != nil {
+		parsed.Architecture = inferOllamaPattern(modelID, ollamaArchitecturePatterns, ollamaOrderedArchKeys)
+		parsed.Family = inferOllamaFamily(modelID, parsed.Architecture)
+		parsed.ParameterSize = inferOllamaParameterSize(modelID)
+		parsed.QuantizationLevel = inferOllamaQuantization(modelID)
+		return parsed
+	}
+
+	for i := 0; i < len(args); i++ {
+		arg := args[i]
+		switch arg {
+		case "-c", "--ctx-size":
+			if i+1 < len(args) {
+				if val, err := strconv.Atoi(args[i+1]); err == nil {
+					parsed.ContextLength = val
+				}
+				i++
+			}
+		case "-a", "--alias":
+			if i+1 < len(args) {
+				parsed.CmdAlias = args[i+1]
+				i++
+			}
+		case "-m", "--model":
+			if i+1 < len(args) {
+				parsed.CmdModelPath = filepath.Base(args[i+1])
+				i++
+			}
+		case "--jinja":
+			if !containsString(parsed.Capabilities, "tools") {
+				parsed.Capabilities = append(parsed.Capabilities, "tools")
+			}
+		}
+	}
+
+	parsed.Architecture = firstKnown(
+		inferOllamaPattern(modelID, ollamaArchitecturePatterns, ollamaOrderedArchKeys),
+		inferOllamaPattern(parsed.CmdAlias, ollamaArchitecturePatterns, ollamaOrderedArchKeys),
+		inferOllamaPattern(parsed.CmdModelPath, ollamaArchitecturePatterns, ollamaOrderedArchKeys),
+	)
+	parsed.Family = firstKnown(
+		inferOllamaFamily(modelID, parsed.Architecture),
+		inferOllamaFamily(parsed.CmdAlias, parsed.Architecture),
+		inferOllamaFamily(parsed.CmdModelPath, parsed.Architecture),
+	)
+	parsed.ParameterSize = firstKnown(
+		inferOllamaParameterSize(modelID),
+		inferOllamaParameterSize(parsed.CmdAlias),
+		inferOllamaParameterSize(parsed.CmdModelPath),
+	)
+	parsed.QuantizationLevel = firstKnown(
+		inferOllamaQuantization(modelID),
+		inferOllamaQuantization(parsed.CmdAlias),
+		inferOllamaQuantization(parsed.CmdModelPath),
+	)
+	return parsed
+}
+
+func ollamaDetailsForModel(model string, modelCfg config.ModelConfig) ollamaModelDetails {
+	metadata := modelCfg.Metadata
+	parsed := NewLlamaServerParser().Parse(modelCfg.Cmd, model)
+	details := ollamaModelDetails{Format: "gguf"}
+	if family, ok := metadata["family"].(string); ok && family != "" {
+		details.Family = family
+	} else if parsed.Family != "" {
+		details.Family = parsed.Family
+	} else if arch, ok := metadata["architecture"].(string); ok && arch != "" {
+		details.Family = inferOllamaFamily(model, arch)
+	} else {
+		details.Family = inferOllamaFamily(model, inferOllamaPattern(model, ollamaArchitecturePatterns, ollamaOrderedArchKeys))
+	}
+	if details.Family != "" && details.Family != "unknown" {
+		details.Families = []string{details.Family}
+	}
+	if paramSize, ok := metadata["parameterSize"].(string); ok && paramSize != "" {
+		details.ParameterSize = paramSize
+	} else if parsed.ParameterSize != "" {
+		details.ParameterSize = parsed.ParameterSize
+	} else {
+		details.ParameterSize = inferOllamaParameterSize(model)
+	}
+	if quant, ok := metadata["quantizationLevel"].(string); ok && quant != "" {
+		details.QuantizationLevel = quant
+	} else if parsed.QuantizationLevel != "" {
+		details.QuantizationLevel = parsed.QuantizationLevel
+	} else {
+		details.QuantizationLevel = inferOllamaQuantization(model)
+	}
+	details.ContextLength = knownContextLength(modelCfg, parsed.ContextLength)
+	return details
+}
+
+func knownContextLength(modelCfg config.ModelConfig, parsedContext int) int {
+	if parsedContext > 0 {
+		return parsedContext
+	}
+	if modelCfg.Capabilities.Context > 0 {
+		return modelCfg.Capabilities.Context
+	}
+	if value := metadataInt(modelCfg.Metadata, "contextLength", 0); value > 0 {
+		return value
+	}
+	return metadataInt(modelCfg.Metadata, "context_length", 0)
+}
+
+func ollamaCapabilitiesForModel(modelCfg config.ModelConfig) []string {
+	if values, ok := modelCfg.Metadata["capabilities"].([]any); ok && len(values) > 0 {
+		caps := make([]string, 0, len(values))
+		for _, item := range values {
+			if s, ok := item.(string); ok && s != "" {
+				caps = append(caps, s)
+			}
+		}
+		if len(caps) > 0 {
+			return caps
+		}
+	}
+
+	caps := []string{"completion"}
+	if modelCfg.Capabilities.Tools {
+		caps = append(caps, "tools")
+	}
+	return caps
+}
+
+func metadataString(metadata map[string]any, key string, fallback string) string {
+	if v, ok := metadata[key].(string); ok && v != "" {
+		return v
+	}
+	if fallback != "" {
+		return fallback
+	}
+	return "unknown"
+}
+
+func metadataInt(metadata map[string]any, key string, fallback int) int {
+	switch v := metadata[key].(type) {
+	case int:
+		if v != 0 {
+			return v
+		}
+	case int64:
+		if v != 0 {
+			return int(v)
+		}
+	case float64:
+		if v != 0 {
+			return int(v)
+		}
+	}
+	return fallback
+}
+
+func firstKnown(values ...string) string {
+	for _, value := range values {
+		if value != "" && value != "unknown" {
+			return value
+		}
+	}
+	return "unknown"
+}
+
+func containsString(values []string, needle string) bool {
+	for _, value := range values {
+		if value == needle {
+			return true
+		}
+	}
+	return false
+}
+
+func inferOllamaPattern(name string, patterns map[string]*regexp.Regexp, orderedKeys []string) string {
+	lower := strings.ToLower(name)
+	for _, key := range orderedKeys {
+		if pattern := patterns[key]; pattern != nil && pattern.MatchString(lower) {
+			return key
+		}
+	}
+	return "unknown"
+}
+func inferOllamaFamily(model string, arch string) string {
+	if arch != "" && arch != "unknown" {
+		return arch
+	}
+	return inferOllamaPattern(model, ollamaArchitecturePatterns, ollamaOrderedArchKeys)
+}
+func inferOllamaParameterSize(name string) string {
+	if match := ollamaParameterSizePattern.FindStringSubmatch(name); len(match) > 1 {
+		return strings.ToUpper(match[1] + "B")
+	}
+	return "unknown"
+}
+func inferOllamaQuantization(name string) string {
+	for _, pattern := range ollamaQuantizationPatterns {
+		if match := pattern.FindString(name); match != "" {
+			return strings.ToUpper(match)
+		}
+	}
+	return "unknown"
+}
+func digestForModel(model string) string {
+	sum := sha256.Sum256([]byte(model))
+	return fmt.Sprintf("%x", sum[:])
+}
