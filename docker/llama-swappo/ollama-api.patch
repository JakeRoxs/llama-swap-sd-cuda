+func (s *Server) handleOllamaChat(w http.ResponseWriter, r *http.Request) {
+	var req ollamaChatRequest
+	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
+		writeOllamaError(w, http.StatusBadRequest, fmt.Sprintf("Invalid request: %v", err))
+		return
+	}
+	if err := validateOllamaToolRequest(&req); err != nil {
+		writeOllamaError(w, http.StatusBadRequest, err.Error())
+		return
+	}
+	if req.Model == "" {
+		writeOllamaError(w, http.StatusBadRequest, "Model name is required.")
+		return
+	}
+
+	realModel, upstreamModel, ok := s.resolveOllamaModel(req.Model)
+	if !ok {
+		writeOllamaError(w, http.StatusNotFound, "model not found")
+		return
+	}
+
+	stream := true
+	if req.Stream != nil {
+		stream = *req.Stream
+	}
+	body := map[string]any{
+		"model":    upstreamModel,
+		"messages": ollamaMessagesToOpenAI(req.Messages),
+		"stream":   stream,
+	}
+	mergeOptions(body, req.Options)
+	if tools := ollamaToolsToOpenAI(req.Tools); len(tools) > 0 {
+		body["tools"] = tools
+	}
+	if req.ToolChoice != nil {
+		body["tool_choice"] = req.ToolChoice
+	}
+	applyOllamaFormat(body, req.Format)
+	applyOllamaThink(body, req.Think)
+	applyChatTemplateKwargs(body, s.cfg.Models[realModel].ChatTemplateKwargs)
+
+	if stream {
+		w.Header().Set("Content-Type", "application/x-ndjson")
+		s.streamOllama(w, r, req.Model, realModel, "/v1/chat/completions", body, true)
+		return
+	}
+
+	rr, ok := s.dispatchOllama(w, r, req.Model, realModel, "/v1/chat/completions", body, false)
+	if !ok {
+		return
+	}
+	var resp openAIChatResponse
+	if err := json.Unmarshal(rr.Body.Bytes(), &resp); err != nil || len(resp.Choices) == 0 {
+		copyUpstreamResponse(w, rr)
+		return
+	}
+	choice := resp.Choices[0]
+	writeOllamaJSON(w, http.StatusOK, ollamaChatResponse{
+		Model:     req.Model,
+		CreatedAt: time.Now().UTC(),
+		Message: ollamaMessage{
+			Role:      defaultString(openAIRoleToOllama(choice.Message.Role), "assistant"),
+			Content:   choice.Message.Content,
+			Thinking:  choice.Message.ReasoningContent,
+			ToolCalls: openAIToolCallsToOllama(choice.Message.ToolCalls),
+		},
+		Done:            true,
+		DoneReason:      openAIFinishReasonToOllama(choice.FinishReason),
+		PromptEvalCount: resp.Usage.PromptTokens,
+		EvalCount:       resp.Usage.CompletionTokens,
+	})
+}
