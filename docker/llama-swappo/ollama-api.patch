+func (s *Server) resolveOllamaModel(requested string) (realModel string, upstreamModel string, ok bool) {
+	realModel, ok = s.cfg.RealModelName(requested)
+	if !ok {
+		realModel = requested
+	}
+	cfg, exists := s.cfg.Models[realModel]
+	if !exists && !s.peer.Handles(realModel) {
+		return realModel, requested, false
+	}
+	upstreamModel = realModel
+	if cfg.UseModelName != "" {
+		upstreamModel = cfg.UseModelName
+	}
+	return realModel, upstreamModel, true
+}
+
+func (s *Server) dispatchOllama(w http.ResponseWriter, parent *http.Request, requestedModel string, realModel string, path string, body map[string]any, streaming bool) (*httptest.ResponseRecorder, bool) {
+	req, err := newOllamaUpstreamRequest(parent, requestedModel, realModel, path, body, streaming)
+	if err != nil {
+		writeOllamaError(w, http.StatusInternalServerError, err.Error())
+		return nil, false
+	}
+	rr := httptest.NewRecorder()
+	if !s.serveOllamaUpstream(rr, req, realModel) {
+		writeOllamaError(w, http.StatusNotFound, "model not found")
+		return nil, false
+	}
+	if rr.Code >= 400 {
+		copyUpstreamResponse(w, rr)
+		return nil, false
+	}
+	return rr, true
+}
+
+func (s *Server) streamOllama(w http.ResponseWriter, parent *http.Request, requestedModel string, realModel string, path string, body map[string]any, isChat bool) {
+	req, err := newOllamaUpstreamRequest(parent, requestedModel, realModel, path, body, true)
+	if err != nil {
+		writeOllamaError(w, http.StatusInternalServerError, err.Error())
+		return
+	}
+	trw := newOllamaStreamWriter(w, requestedModel, isChat)
+	if !s.serveOllamaUpstream(trw, req, realModel) {
+		writeOllamaError(w, http.StatusNotFound, "model not found")
+		return
+	}
+	trw.Flush()
+}
+
+func newOllamaUpstreamRequest(parent *http.Request, requestedModel string, realModel string, path string, body map[string]any, streaming bool) (*http.Request, error) {
+	payload, err := json.Marshal(body)
+	if err != nil {
+		return nil, fmt.Errorf("failed to marshal upstream request")
+	}
+	req, err := http.NewRequestWithContext(parent.Context(), http.MethodPost, path, bytes.NewReader(payload))
+	if err != nil {
+		return nil, fmt.Errorf("failed to create upstream request")
+	}
+	req.Header = parent.Header.Clone()
+	req.Header.Set("Content-Type", "application/json")
+	req.Header.Set("Accept", "application/json")
+	req.ContentLength = int64(len(payload))
+	req = req.WithContext(shared.SetContext(req.Context(), shared.ReqContextData{
+		ApiKey:           shared.ExtractAPIKey(parent),
+		Model:            requestedModel,
+		ModelID:          realModel,
+		Streaming:        streaming,
+		SendLoadingState: false,
+		Metadata:         map[string]string{},
+	}))
+	return req, nil
+}
+
+func (s *Server) serveOllamaUpstream(w http.ResponseWriter, req *http.Request, realModel string) bool {
+	switch {
+	case s.local.Handles(realModel):
+		s.local.ServeHTTP(w, req)
+	case s.peer.Handles(realModel):
+		s.peer.ServeHTTP(w, req)
+	default:
+		return false
+	}
+	return true
+}
+
+type accumulatedToolCall struct {
+	ID        string
+	Type      string
+	Name      string
+	Arguments strings.Builder
+}
+
+type ollamaStreamWriter struct {
+	dst            http.ResponseWriter
+	model          string
+	isChat         bool
+	buffer         bytes.Buffer
+	toolCallBuffer map[int]*accumulatedToolCall
+	rawPassthrough bool
+	wroteHeader    bool
+}
+
+func newOllamaStreamWriter(dst http.ResponseWriter, model string, isChat bool) *ollamaStreamWriter {
+	return &ollamaStreamWriter{
+		dst:            dst,
+		model:          model,
+		isChat:         isChat,
+		toolCallBuffer: make(map[int]*accumulatedToolCall),
+	}
+}
+
+func (w *ollamaStreamWriter) Header() http.Header {
+	return w.dst.Header()
+}
+
+func (w *ollamaStreamWriter) WriteHeader(statusCode int) {
+	if w.wroteHeader {
+		return
+	}
+	w.wroteHeader = true
+	if statusCode >= 400 {
+		w.rawPassthrough = true
+		w.dst.WriteHeader(statusCode)
+		return
+	}
+	w.dst.Header().Set("Content-Type", "application/x-ndjson")
+	w.dst.WriteHeader(statusCode)
+}
+
+func (w *ollamaStreamWriter) Write(data []byte) (int, error) {
+	if w.rawPassthrough {
+		_, err := w.dst.Write(data)
+		return len(data), err
+	}
+	w.buffer.Write(data)
+	w.Flush()
+	return len(data), nil
+}
+
+func (w *ollamaStreamWriter) Flush() {
+	if w.rawPassthrough {
+		if flusher, ok := w.dst.(http.Flusher); ok {
+			flusher.Flush()
+		}
+		return
+	}
+
+	var remaining bytes.Buffer
+	scanner := bufio.NewScanner(bytes.NewReader(w.buffer.Bytes()))
+	for scanner.Scan() {
+		line := scanner.Text()
+		if strings.HasPrefix(line, "data: ") {
+			w.transformSSE(strings.TrimPrefix(line, "data: "))
+		} else if strings.TrimSpace(line) != "" {
+			_, _ = w.dst.Write([]byte(line + "\n"))
+		}
+	}
+	if len(w.buffer.Bytes()) > 0 && !bytes.HasSuffix(w.buffer.Bytes(), []byte("\n")) {
+		last := w.buffer.Bytes()
+		if idx := bytes.LastIndexByte(last, '\n'); idx >= 0 {
+			remaining.Write(last[idx+1:])
+		} else {
+			remaining.Write(last)
+		}
+	}
+	w.buffer = remaining
+
+	if flusher, ok := w.dst.(http.Flusher); ok {
+		flusher.Flush()
+	}
+}
+
+func (w *ollamaStreamWriter) transformSSE(data string) {
+	if data == "[DONE]" || strings.TrimSpace(data) == "" {
+		return
+	}
+	if w.isChat {
+		w.transformChatChunk(data)
+		return
+	}
+	w.transformGenerateChunk(data)
+}
+
+func (w *ollamaStreamWriter) transformChatChunk(data string) {
+	var chunk openAIChatStreamResponse
+	if err := json.Unmarshal([]byte(data), &chunk); err != nil || len(chunk.Choices) == 0 {
+		return
+	}
+	choice := chunk.Choices[0]
+	message := ollamaMessage{
+		Role:     openAIRoleToOllama(choice.Delta.Role),
+		Content:  choice.Delta.Content,
+		Thinking: choice.Delta.ReasoningContent,
+	}
+	for _, delta := range choice.Delta.ToolCalls {
+		acc := w.toolCallBuffer[delta.Index]
+		if acc == nil {
+			acc = &accumulatedToolCall{}
+			w.toolCallBuffer[delta.Index] = acc
+		}
+		if delta.ID != "" {
+			acc.ID = delta.ID
+		}
+		if delta.Type != "" {
+			acc.Type = delta.Type
+		}
+		if delta.Function.Name != "" {
+			acc.Name = delta.Function.Name
+		}
+		acc.Arguments.WriteString(delta.Function.Arguments)
+	}
+
+	if choice.FinishReason != "" && len(w.toolCallBuffer) > 0 {
+		toolCalls := w.accumulatedOllamaToolCalls()
+		if len(toolCalls) > 0 {
+			message.ToolCalls = toolCalls
+			w.writeNDJSON(ollamaChatResponse{
+				Model:      w.model,
+				CreatedAt:  time.Now().UTC(),
+				Message:    messageWithDefaultRole(message),
+				Done:       false,
+				DoneReason: openAIFinishReasonToOllama(choice.FinishReason),
+			})
+		}
+		w.writeNDJSON(ollamaChatResponse{
+			Model:           w.model,
+			CreatedAt:       time.Now().UTC(),
+			Message:         ollamaMessage{Role: "assistant"},
+			Done:            true,
+			DoneReason:      openAIFinishReasonToOllama(choice.FinishReason),
+			PromptEvalCount: usagePromptTokens(chunk.Usage),
+			EvalCount:       usageCompletionTokens(chunk.Usage),
+		})
+		return
+	}
+
+	w.writeNDJSON(ollamaChatResponse{
+		Model:           w.model,
+		CreatedAt:       time.Now().UTC(),
+		Message:         messageWithDefaultRole(message),
+		Done:            choice.FinishReason != "",
+		DoneReason:      openAIFinishReasonToOllama(choice.FinishReason),
+		PromptEvalCount: usagePromptTokens(chunk.Usage),
+		EvalCount:       usageCompletionTokens(chunk.Usage),
+	})
+}
+
+func (w *ollamaStreamWriter) transformGenerateChunk(data string) {
+	var chunk openAICompletionStreamResponse
+	if err := json.Unmarshal([]byte(data), &chunk); err != nil || len(chunk.Choices) == 0 {
+		return
+	}
+	choice := chunk.Choices[0]
+	w.writeNDJSON(ollamaGenerateResponse{
+		Model:           w.model,
+		CreatedAt:       time.Now().UTC(),
+		Response:        choice.Text,
+		Done:            choice.FinishReason != "",
+		DoneReason:      openAIFinishReasonToOllama(choice.FinishReason),
+		PromptEvalCount: usagePromptTokens(chunk.Usage),
+		EvalCount:       usageCompletionTokens(chunk.Usage),
+	})
+}
+
+func (w *ollamaStreamWriter) accumulatedOllamaToolCalls() []ollamaToolCall {
+	indices := make([]int, 0, len(w.toolCallBuffer))
+	for idx := range w.toolCallBuffer {
+		indices = append(indices, idx)
+	}
+	sort.Ints(indices)
+
+	calls := make([]ollamaToolCall, 0, len(indices))
+	for _, idx := range indices {
+		acc := w.toolCallBuffer[idx]
+		if acc == nil || acc.Name == "" {
+			continue
+		}
+		args := map[string]any{}
+		if raw := acc.Arguments.String(); raw != "" {
+			_ = json.Unmarshal([]byte(raw), &args)
+		}
+		calls = append(calls, ollamaToolCall{
+			ID:   acc.ID,
+			Type: defaultString(acc.Type, "function"),
+			Function: ollamaToolCallFunc{
+				Index:     idx,
+				Name:      acc.Name,
+				Arguments: args,
+			},
+		})
+	}
+	return calls
+}
+
+func (w *ollamaStreamWriter) writeNDJSON(v any) {
+	b, err := json.Marshal(v)
+	if err != nil {
+		return
+	}
+	_, _ = w.dst.Write(append(b, '\n'))
+}
+
+func mergeOptions(dst map[string]any, options map[string]any) {
+	for k, v := range options {
+		if _, exists := dst[k]; !exists {
+			dst[k] = v
+		}
+	}
+}
+
+func applyOllamaFormat(dst map[string]any, format any) {
+	switch f := format.(type) {
+	case nil:
+	case string:
+		if f == "json" {
+			dst["response_format"] = map[string]any{"type": "json_object"}
+		}
+	case map[string]any:
+		dst["response_format"] = map[string]any{"type": "json_schema", "schema": f}
+	}
+}
+
+func applyOllamaThink(dst map[string]any, think any) {
+	if think == nil {
+		return
+	}
+	kwargs, _ := dst["chat_template_kwargs"].(map[string]any)
+	if kwargs == nil {
+		kwargs = map[string]any{}
+		dst["chat_template_kwargs"] = kwargs
+	}
+	switch v := think.(type) {
+	case bool:
+		kwargs["enable_thinking"] = v
+	case string:
+		kwargs["enable_thinking"] = v == "high" || v == "medium" || v == "low" || v == "max"
+		kwargs["thinking_level"] = v
+	}
+}
+
+func applyChatTemplateKwargs(dst map[string]any, defaults map[string]any) {
+	if len(defaults) == 0 {
+		return
+	}
+	kwargs, _ := dst["chat_template_kwargs"].(map[string]any)
+	if kwargs == nil {
+		kwargs = map[string]any{}
+		dst["chat_template_kwargs"] = kwargs
+	}
+	for k, v := range defaults {
+		if _, exists := kwargs[k]; !exists {
+			kwargs[k] = v
+		}
+	}
+}
+
+func copyIfNotZero(dst map[string]any, key string, value any) {
+	switch v := value.(type) {
+	case string:
+		if v != "" {
+			dst[key] = v
+		}
+	case bool:
+		if v {
+			dst[key] = v
+		}
+	case []string:
+		if len(v) > 0 {
+			dst[key] = v
+		}
+	default:
+		if v != nil {
+			dst[key] = v
+		}
+	}
+}
+
+func copyUpstreamResponse(w http.ResponseWriter, rr *httptest.ResponseRecorder) {
+	copyHeader(w.Header(), rr.Header())
+	w.WriteHeader(rr.Code)
+	_, _ = io.Copy(w, rr.Body)
+}
+
+func copyHeader(dst, src http.Header) {
+	for k, values := range src {
+		for _, v := range values {
+			dst.Add(k, v)
+		}
+	}
+}
+
+func setOllamaCORS(w http.ResponseWriter, r *http.Request) {
+	if origin := r.Header.Get("Origin"); origin != "" {
+		w.Header().Set("Access-Control-Allow-Origin", origin)
+	}
+}
+
+func defaultString(value, fallback string) string {
+	if strings.TrimSpace(value) == "" {
+		return fallback
+	}
+	return value
+}
+
+func firstNonEmpty(values ...string) string {
+	for _, v := range values {
+		if strings.TrimSpace(v) != "" {
+			return v
+		}
+	}
+	return ""
+}
+
+func messageWithDefaultRole(message ollamaMessage) ollamaMessage {
+	if message.Role == "" {
+		message.Role = "assistant"
+	}
+	return message
+}
+
+func usagePromptTokens(usage *openAIUsage) int {
+	if usage == nil {
+		return 0
+	}
+	return usage.PromptTokens
+}
+
+func usageCompletionTokens(usage *openAIUsage) int {
+	if usage == nil {
+		return 0
+	}
+	return usage.CompletionTokens
+}
+
+func openAIFinishReasonToOllama(reason string) string {
+	switch reason {
+	case "", "stop", "length", "content_filter", "tool_calls":
+		return reason
+	default:
+		return "unknown"
+	}
+}
+
+func openAIRoleToOllama(role string) string {
+	switch role {
+	case "system", "user", "assistant", "tool":
+		return role
+	default:
+		return role
+	}
+}
+
+func ollamaMessagesToOpenAI(ollamaMsgs []ollamaMessage) []map[string]any {
+	openAIMsgs := make([]map[string]any, 0, len(ollamaMsgs))
+	for i, msg := range ollamaMsgs {
+		openAIMsg := map[string]any{
+			"role":    msg.Role,
+			"content": msg.Content,
+		}
+		if len(msg.Images) > 0 {
+			openAIMsg["images"] = msg.Images
+		}
+		if len(msg.ToolCalls) > 0 {
+			calls := make([]map[string]any, 0, len(msg.ToolCalls))
+			for j, tc := range msg.ToolCalls {
+				if tc.Function.Name == "" {
+					continue
+				}
+				argsJSON, _ := json.Marshal(tc.Function.Arguments)
+				toolID := tc.ID
+				if toolID == "" {
+					toolID = fmt.Sprintf("call_%d_%d", i, j)
+				}
+				calls = append(calls, map[string]any{
+					"id":   toolID,
+					"type": defaultString(tc.Type, "function"),
+					"function": map[string]any{
+						"name":      tc.Function.Name,
+						"arguments": string(argsJSON),
+					},
+				})
+			}
+			if len(calls) > 0 {
+				openAIMsg["tool_calls"] = calls
+			}
+		}
+		if msg.Role == "tool" {
+			switch {
+			case msg.ToolCallID != "":
+				openAIMsg["tool_call_id"] = msg.ToolCallID
+			case msg.ToolName != "":
+				openAIMsg["tool_call_id"] = fmt.Sprintf("call_%s_%d", msg.ToolName, i)
+			}
+			if msg.Content == "" {
+				openAIMsg["content"] = "null"
+			}
+		}
+		openAIMsgs = append(openAIMsgs, openAIMsg)
+	}
+	return openAIMsgs
+}
+
+func ollamaToolsToOpenAI(tools []ollamaTool) []map[string]any {
+	if len(tools) == 0 {
+		return nil
+	}
+	openAITools := make([]map[string]any, 0, len(tools))
+	for _, tool := range tools {
+		openAITools = append(openAITools, map[string]any{
+			"type": defaultString(tool.Type, "function"),
+			"function": map[string]any{
+				"name":        tool.Function.Name,
+				"description": tool.Function.Description,
+				"parameters":  tool.Function.Parameters,
+			},
+		})
+	}
+	return openAITools
+}
+
+func openAIToolCallsToOllama(toolCalls []openAIToolCall) []ollamaToolCall {
+	if len(toolCalls) == 0 {
+		return nil
+	}
+	out := make([]ollamaToolCall, 0, len(toolCalls))
+	for i, tc := range toolCalls {
+		args := map[string]any{}
+		_ = json.Unmarshal([]byte(tc.Function.Arguments), &args)
+		out = append(out, ollamaToolCall{
+			ID:   tc.ID,
+			Type: tc.Type,
+			Function: ollamaToolCallFunc{
+				Index:     i,
+				Name:      tc.Function.Name,
+				Arguments: args,
+			},
+		})
+	}
+	return out
+}
+
+func validateOllamaToolRequest(req *ollamaChatRequest) error {
+	for i, tool := range req.Tools {
+		if defaultString(tool.Type, "function") != "function" {
+			return fmt.Errorf("tool %d: only 'function' type is supported", i)
+		}
+		if tool.Function.Name == "" {
+			return fmt.Errorf("tool %d: missing function name", i)
+		}
+	}
+
+	validMessages := make([]ollamaMessage, 0, len(req.Messages))
+	for i, msg := range req.Messages {
+		if msg.Role == "assistant" && len(msg.ToolCalls) > 0 {
+			validCalls := make([]ollamaToolCall, 0, len(msg.ToolCalls))
+			for _, tc := range msg.ToolCalls {
+				if tc.Function.Name != "" {
+					validCalls = append(validCalls, tc)
+				}
+			}
+			req.Messages[i].ToolCalls = validCalls
+			msg.ToolCalls = validCalls
+		}
+		if msg.Role == "tool" && msg.ToolCallID == "" && msg.ToolName == "" {
+			continue
+		}
+		validMessages = append(validMessages, msg)
+	}
+	req.Messages = validMessages
+	return nil
+}
